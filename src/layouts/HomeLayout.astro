---
import HomeLatestPublications from "../components/HomeLatestPublications.astro";
import HomeSectionLinks from "../components/HomeSectionLinks.astro";
import HomeUpcomingEventsList from "../components/HomeUpcomingEventsList.astro";
import BaseLayout from "./BaseLayout.astro";
---

<BaseLayout>
    <div class="flex flex-col gap-x-6 items-center">
        <div class="lg:w-2/3 mx-auto text-center">
            <h1 class="text-5xl lg:text-7xl pb-10 lg:py-10">
                Santiago Mind and Cognition
            </h1>
            <div><slot /></div>
        </div>
        <HomeSectionLinks />
    </div>
    <div class="lg:grid lg:grid-cols-8 gap-x-12">
        <div class="col-span-3">
            <HomeUpcomingEventsList />
        </div>
        <hr class="lg:hidden my-6" />
        <div class="col-span-5">
            <HomeLatestPublications />
        </div>
    </div>
</BaseLayout>
