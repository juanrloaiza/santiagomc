---
import { YouTube } from "@astro-community/astro-embed-youtube";

const { url, title, author, event, institution, date } = Astro.props;
---

<div class="mt-2">
    <YouTube id={url} posterQuality="high" />
    <a href={url}>
        <h3 class="text-xl mt-2">{title}</h3>
        {author && <div>{author}</div>}

        <div class="text-sm">
            {event && <div>{event}</div>}
            {institution}
            <br />
            {date}
        </div>
    </a>
</div>
